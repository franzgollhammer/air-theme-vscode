{
  "name": "air-theme",
  "displayName": "Air",
  "version": "1.0.0",
  "description": "VS Code port of JetBrains Air — a calm, near-black dark theme with purple keywords, pink strings, amber numbers and green types.",
  "categories": [
    "Themes"
  ],
  "keywords": [
    "Theme",
    "Dark Theme",
    "Air",
    "JetBrains",
    "JetBrains Air",
    "Jet Brains"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/franzgollhammer/air-theme-vscode"
  },
  "license": "MIT",
  "author": {
    "name": "Franz Gollhammer"
  },
  "publisher": "franzgollhammer",
  "scripts": {
    "dev": "code --extensionDevelopmentPath=$PWD",
    "dev:insiders": "code-insiders --extensionDevelopmentPath=$PWD",
    "package": "npx @vscode/vsce package",
    "install:local": "npx @vscode/vsce package && code --install-extension $(ls -t *.vsix | head -1) --force",
    "publish": "npx @vscode/vsce publish && bash -c 'source ~/.zshrc 2>/dev/null; npx ovsx publish -p \"$OVSX_PAT\"'"
  },
  "contributes": {
    "themes": [
      {
        "label": "Air dark",
        "path": "./themes/air-dark-color-theme.json",
        "uiTheme": "vs-dark"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.8"
  },
  "engines": {
    "vscode": "^1.82.0"
  }
}
